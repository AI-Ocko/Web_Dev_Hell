---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const entries = (await getCollection("recipes")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Base title="Recipes">
  <h1>Recipes</h1>
  {entries.length === 0 ? (
    <p>No recipes yet.</p>
  ) : (
    <ul class="entries">
      {entries.map((e) => (
        <li>
          <a href={`${base}/recipes/${e.slug}`}>{e.data.title}</a>
          <span class="meta">
            {e.data.tags.map((t) => <span class="tag">{t}</span>)}
            {e.data.time ?? ""}
          </span>
        </li>
      ))}
    </ul>
  )}
</Base>
