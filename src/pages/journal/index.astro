---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const entries = (await getCollection("journal", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.number - a.data.number
);
---

<Base title="Journal">
  <h1>Journal</h1>
  {entries.length === 0 ? (
    <p>No entries yet.</p>
  ) : (
    <ul class="entries">
      {entries.map((e) => (
        <li>
          <a href={`${base}/journal/${e.slug}`}>
            {String(e.data.number).padStart(3, "0")}: {e.data.title}
          </a>
          <span class="meta">{e.data.date.toISOString().slice(0, 10)}</span>
        </li>
      ))}
    </ul>
  )}
</Base>
