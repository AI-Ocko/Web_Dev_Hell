---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const journal = (await getCollection("journal", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const sections = [
  { href: "/journal", title: "Journal"},
  { href: "/reviews", title: "Reviews"},
  { href: "/watchlist", title: "Watchlist"},
  { href: "/recipes", title: "Recipes"},
  { href: "/projects", title: "Projects"},
];
---

<Base title="Web Dev Hell">
  <h1>Web Dev Hell</h1>
  <p>
  A public notebook.
  </p>

  <ul class="entries">
    {
      sections.map((s) => (
        <li>
          <a href={`${base}${s.href}`}>{s.title}</a>
          <span class="meta">{s.blurb}</span>
        </li>
      ))
    }
  </ul>

  {journal.length > 0 && (
    <>
      <h2>Recent journal</h2>
      <ul class="entries">
        {journal.map((e) => (
          <li>
            <a href={`${base}/journal/${e.slug}`}>
              {String(e.data.number).padStart(3, "0")}: {e.data.title}
            </a>
            <span class="meta">{e.data.date.toISOString().slice(0, 10)}</span>
          </li>
        ))}
      </ul>
    </>
  )}
</Base>
